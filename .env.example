# ───── Database ─────
DATABASE_URL=postgres://rps_dev:rps_dev_password@localhost:5433/rps?sslmode=disable
POSTGRES_DB=rps
POSTGRES_USER=rps_dev
POSTGRES_PASSWORD=rps_dev_password

# ───── JWT ─────
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars-long
JWT_REFRESH_SECRET=change-me-too-also-min-32-chars-long
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ───── QR Hash ─────
QR_HASH_SECRET=change-me-this-signs-every-qr-code

# ───── Backend ─────
PORT=3000
ENV=development
LOG_LEVEL=debug

# ───── CORS ─────
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ───── Anthropic (Phase 7 — leave blank for now) ─────
ANTHROPIC_API_KEY=