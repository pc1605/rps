                  "pm.test('Response status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response data is an array', function () {",
                  "    pm.expect(responseData).to.be.an('array');",
                  "});",
                  "pm.test('Each car model has id, brand_name, name, size_class', function () {",
                  "    responseData.forEach(function (model) {",
                  "        pm.expect(model).to.have.property('id');",
                  "        pm.expect(model).to.have.property('brand_name');",
                  "        pm.expect(model).to.have.property('name');",
                  "        pm.expect(model).to.have.property('size_class');",
                  "    });",
