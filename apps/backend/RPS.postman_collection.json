              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"car_model_id\": 9999,\n  \"quantity\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/batches",
              "host": ["{{baseUrl}}"],
              "path": ["batches"]
            }
          }
        },
        {
          "name": "Create Batch (no token)",
